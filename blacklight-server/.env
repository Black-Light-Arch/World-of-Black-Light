# ============================================================
#  WORLD OF BLACKLIGHT — Environment Variables
# ============================================================

# ── JWT Secret ───────────────────────────────────────────────
# Change this to any long random string in production
JWT_SECRET=blacklight_very_secret_key_change_me_in_production

# ── Gemini API Key ───────────────────────────────────────────
# Get a 100% free API key from https://aistudio.google.com/
# No credit card or payment is required for the free tier.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Server Port ──────────────────────────────────────────────
PORT=3000
