# ── MongoDB Atlas ────────────────────────────────────────────
# Get your connection string from atlas.mongodb.com:
#   1. Create a free cluster
#   2. Database Access → Add user with password
#   3. Network Access → Allow 0.0.0.0/0 (or your IP)
#   4. Connect → Drivers → copy the connection string
#   5. Replace <username> and <password> below
MONGO_URI=mongodb+srv://shehramabdullah1_db_user:Black%20Light%201@worldofblacklight.otgrt9w.mongodb.net/blacklight?retryWrites=true&w=majority&appName=WorldOfBlackLight

# ── JWT Secret ───────────────────────────────────────────────
# Change this to any long random string in production
JWT_SECRET=blacklight_very_secret_key_change_me_in_production

# ── NVIDIA NIM API Key (for DeepSeek AI Chat) ───────────────
# Uses NVIDIA NIM (OpenAI-compatible) to run DeepSeek-R1
# Get keys from build.nvidia.com
# If left empty, server falls back to rule-based AI
NVIDIA_API_KEY=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

# ── Server Port ──────────────────────────────────────────────
PORT=3000
